#!/usr/bin/env python3
"""vtui-patch-font — make any monospace font fbterm-ready.

Pipeline: [add powerline] -> [box seam + powerline geometry] -> [junction
alignment] -> [fbterm-friendly size report]. Single file so it's easy to share.
"""
VERSION = "0.1.0"

import argparse
import os
import sys

from fontTools.pens.recordingPen import DecomposingRecordingPen
from fontTools.pens.t2CharStringPen import T2CharStringPen
from fontTools.pens.ttGlyphPen import TTGlyphPen
from fontTools.pens.boundsPen import BoundsPen


def _is_cff(font):
    return "CFF " in font


def _adv(font, gname):
    return font["hmtx"][gname][0]


def _rewrite_glyph(font, gname, adv, xform):
    """Redraw one glyph through xform(point)->point. Handles CFF and glyf."""
    gs = font.getGlyphSet()
    rec = DecomposingRecordingPen(gs)
    gs[gname].draw(rec)

    def apply(pen):
        for op, args in rec.value:
            if op in ("moveTo", "lineTo"):
                getattr(pen, op)(xform(args[0]))
            elif op == "curveTo":
                pen.curveTo(*[xform(p) for p in args])
            elif op == "qCurveTo":
                pen.qCurveTo(*[xform(p) if p else None for p in args])
            elif op in ("closePath", "endPath"):
                getattr(pen, op)()

    if _is_cff(font):
        cff = font["CFF "].cff
        td = cff[cff.fontNames[0]]
        pen = T2CharStringPen(adv, gs)
        apply(pen)
        td.CharStrings[gname] = pen.getCharString(td.Private)
    else:
        pen = TTGlyphPen(gs)
        apply(pen)
        glyph = pen.glyph()
        font["glyf"][gname] = glyph
        glyph.recalcBounds(font["glyf"])
        font["hmtx"][gname] = (adv, getattr(glyph, "xMin", 0))


def fix_box_seams(font):
    """Clamp box-drawing glyph x-extents to [0, advance] (kills the cell seam)."""
    cmap = font.getBestCmap()
    gs = font.getGlyphSet()
    n = 0
    for cp in range(0x2500, 0x2600):
        g = cmap.get(cp)
        if not g:
            continue
        adv = _adv(font, g)
        bp = BoundsPen(gs)
        gs[g].draw(bp)
        if bp.bounds is None:
            continue
        xmin, _, xmax, _ = bp.bounds
        if xmin >= 0 and xmax <= adv:
            continue
        _rewrite_glyph(font, g, adv, lambda p, adv=adv: (max(0, min(adv, p[0])), p[1]))
        n += 1
    return n


STRETCH = {0xE0B0, 0xE0B2, 0xE0B8, 0xE0BA, 0xE0BC, 0xE0BE} | set(range(0xE0C0, 0xE0C8))
CELL_Y = (-400, 1000)  # U+2588 FULL BLOCK y-bounds == fbterm cell box


def fix_powerline(font):
    """Stretch solid powerline separators to fill the fbterm cell box."""
    cmap = font.getBestCmap()
    gs = font.getGlyphSet()
    n = 0
    for cp in STRETCH:
        g = cmap.get(cp)
        if not g:
            continue
        adv = _adv(font, g)
        bp = BoundsPen(gs)
        gs[g].draw(bp)
        if bp.bounds is None:
            continue
        xmin, ymin, xmax, ymax = bp.bounds
        if xmax == xmin or ymax == ymin:
            continue
        sx = adv / (xmax - xmin)
        sy = (CELL_Y[1] - CELL_Y[0]) / (ymax - ymin)
        _rewrite_glyph(
            font,
            g,
            adv,
            lambda p, _x=xmin, _y=ymin, _sx=sx, _sy=sy: (
                (p[0] - _x) * _sx,
                (p[1] - _y) * _sy + CELL_Y[0],
            ),
        )
        n += 1
    return n


def friendly_sizes(
    advance, upm, lo=8, hi=32, tol=0.12, ascent=None, descent=None, with_cells=False
):
    """fbterm sizes whose cell width lands within `tol` px of a whole pixel.

    Cell width px = size * advance / upm; a large fractional part leaves a dead
    column (seam). Returns a sorted list of sizes, or (size, cell_w, cell_h)
    tuples when with_cells=True (cell_h is None unless ascent/descent given).
    """
    out = []
    for size in range(lo, hi + 1):
        w = size * advance / upm
        dead = min(w % 1, 1 - (w % 1))
        if dead <= tol:
            wc = round(w)
            hc = (
                round(size * ((ascent - descent) / upm)) if ascent is not None else None
            )
            out.append((size, wc, hc) if with_cells else size)
    return out


def junction_classes(font):
    """Split box line/corner/tee glyphs (U+2500-257F) into (up_stem, plain_bar).

    up_stem = ink reaches near the em top (fbterm shoves these down);
    plain_bar = ink tops out at the horizontal bar (rendered correctly).
    Thresholds scale with unitsPerEm so this works for any font.
    """
    cmap = font.getBestCmap()
    gs = font.getGlyphSet()
    upm = font["head"].unitsPerEm
    up, plain = set(), set()
    for cp in range(0x2500, 0x2580):
        g = cmap.get(cp)
        if not g:
            continue
        bp = BoundsPen(gs)
        gs[g].draw(bp)
        if bp.bounds is None:
            continue
        ymax = bp.bounds[3]
        if ymax >= 0.85 * upm:
            up.add(g)
        elif ymax <= 0.55 * upm:
            plain.add(g)
    return up, plain


def default_shove_px(size):
    """Heuristic default fbterm shove: measured 2px at size 15, scaled.

    NOT exact for arbitrary fonts/sizes — the real value depends on the system
    FreeType + fontconfig hinting. Use --verify to measure it on your fbterm.
    """
    return max(1, round(2 * size / 15))


def junction_shift_units(font, size, shove_px):
    """Font units to move the plain-bar glyphs DOWN (negative; font y is up)."""
    upm = font["head"].unitsPerEm
    return -round(shove_px * upm / size)


def align_box_junctions(font, size, shove_px):
    """Shift no-up-stem bar glyphs down so their bar meets the up-stem junctions."""
    _up, plain = junction_classes(font)
    dy = junction_shift_units(font, size, shove_px)
    for g in plain:
        _rewrite_glyph(font, g, _adv(font, g), lambda p, _dy=dy: (p[0], p[1] + _dy))
    return dy


def recommend_size(sizes, lo=14, hi=18):
    """Pick a legible default from friendly sizes: prefer the [lo,hi] band,
    else the size closest to the band's midpoint."""
    if not sizes:
        return None
    band = [s for s in sizes if lo <= s <= hi]
    if band:
        return band[len(band) // 2]
    mid = (lo + hi) / 2
    return min(sizes, key=lambda s: abs(s - mid))


def set_family_name(font, new_family):
    """Rename the font family so the patched font coexists with the original."""
    name = font["name"]
    ps = new_family.replace(" ", "")
    for rec in list(name.names):
        if rec.nameID in (1, 16):  # family / typographic family
            name.setName(
                new_family, rec.nameID, rec.platformID, rec.platEncID, rec.langID
            )
        elif rec.nameID == 4:  # full name
            name.setName(
                new_family, rec.nameID, rec.platformID, rec.platEncID, rec.langID
            )
        elif rec.nameID in (3, 6):  # unique id / postscript name
            name.setName(ps, rec.nameID, rec.platformID, rec.platEncID, rec.langID)
    if _is_cff(font):
        cff = font["CFF "].cff
        cff.fontNames[0] = ps


def _representative_advance(font):
    """Monospace advance width: prefer space, else U+2500, else any glyph."""
    cmap = font.getBestCmap()
    for cp in (0x20, 0x2500):
        g = cmap.get(cp)
        if g:
            return _adv(font, g)
    return next(iter(font["hmtx"].metrics.values()))[0]


def main(argv=None):
    from fontTools.ttLib import TTFont

    p = argparse.ArgumentParser(
        prog="vtui-patch-font", description="Make a mono font fbterm-ready."
    )
    p.add_argument("input", help="input font (.otf/.ttf)")
    p.add_argument(
        "--size",
        type=int,
        default=None,
        help="target fbterm size (default: recommended)",
    )
    p.add_argument(
        "--shove-px",
        type=int,
        default=None,
        help="junction shove override (default: heuristic)",
    )
    p.add_argument("--nerd", action="store_true", help="(later) add full Nerd icon set")
    p.add_argument(
        "--verify",
        action="store_true",
        help="(later) measure junction shove on real fbterm",
    )
    p.add_argument(
        "-o", "--output", default=None, help="output path (default: <stem>-VTui<ext>)"
    )
    args = p.parse_args(argv)

    font = TTFont(args.input)
    upm = font["head"].unitsPerEm
    adv = _representative_advance(font)
    asc = font["hhea"].ascent
    desc = font["hhea"].descent
    friendly = friendly_sizes(adv, upm, ascent=asc, descent=desc, with_cells=True)
    friendly_px = [s for (s, w, h) in friendly]
    size = args.size or recommend_size(friendly_px) or 15
    shove = args.shove_px if args.shove_px is not None else default_shove_px(size)

    have_powerline = 0xE0B0 in font.getBestCmap()
    if have_powerline:
        pass  # glyphs already present; nothing to add
    else:
        print(
            "* adding powerline glyphs ... skipped (install fontforge; --nerd coming)"
        )

    nb = fix_box_seams(font)
    print(f"* fixing box-drawing seams ... done ({nb} glyphs)")
    npl = fix_powerline(font)
    print(f"* fixing powerline separators ... done ({npl} glyphs)")
    align_box_junctions(font, size, shove)
    print(f"* aligning box junctions (exact @{size}px) ... done")

    base_family = font["name"].getDebugName(1) or "Font"
    set_family_name(font, base_family + " VTui")

    if args.output:
        out = args.output
    else:
        stem, ext = os.path.splitext(args.input)
        out = f"{os.path.basename(stem)}-VTui{ext}"
    font.save(out)

    print(f"\nPatched font saved to {out}")
    rec = recommend_size(friendly_px)
    pretty = ", ".join(f"{s}px*" if s == rec else f"{s}px" for s in friendly_px)
    print(f"FbTerm-friendly sizes: {pretty}   (* recommended)")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
