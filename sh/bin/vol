#!/usr/bin/env bash
# vol — get or set system volume (0-100) via vol.<tag> providers.
#
# Sourced directly (not via include-source): the dispatcher lib does not
# resolve through include-source in this worktree (BASH_LIB_PATH points at the
# main repo). Same pattern as clipin/clipout.
source "$(dirname "$(readlink -f "$0")")/../lib/vol.sh"

usage() {
  cat >&2 <<'EOF'
usage: vol                     show current volume (0-100)
       vol <0-100>             set volume
       vol +N | -N             adjust volume, clamped to 0-100
       vol mute [on|off|toggle]  set mute state (default: toggle)
       vol muted               show mute state (on|off)
EOF
}

main() {
  : 'Get/set volume or mute state through the provider dispatcher.

      @return 0 on success; 1 bad usage; 3 no capable provider
  '
  # No args: show current volume
  if (( $# == 0 )); then
    vol::dispatch get volume
    return
  fi

  local arg="$1"
  case "$arg" in
    mute)
      local state="${2:-toggle}"
      case "$state" in
        on|off|toggle) vol::dispatch set mute "$state" ;;
        *) usage; return 1 ;;
      esac
      return
      ;;
    muted)
      vol::dispatch get mute
      return
      ;;
    -h|--help)
      usage; return 0
      ;;
  esac

  (( $# == 1 )) || { usage; return 1; }

  local -i level
  # Relative adjustment: +N or -N (clamped); absolute: 0-100
  if [[ "$arg" =~ ^[+-][0-9]+$ ]]; then
    local -i current
    current=$(vol::dispatch get volume) || return $?
    (( level = current + arg ))
    (( level < 0 )) && level=0
    (( level > 100 )) && level=100
  elif [[ "$arg" =~ ^[0-9]+$ ]] && (( arg <= 100 )); then
    level="$arg"
  else
    usage; return 1
  fi

  vol::dispatch set volume "$level"
}

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@"
