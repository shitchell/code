#!/usr/bin/env bash
#
# Escape a string for use in a regular expression


## imports #####################################################################
################################################################################

include-source 'parseargs.sh'


## options #####################################################################
################################################################################

function setup-options() {
    parseargs-set-usage "usage: $(basename "${0}") [-h] [-E|-B|-P|-A|-J] [--] STRING..."
    parseargs-set-help "escape regular expression characters in a string"
    parseargs-add-flag "-E/--extended" --const extended --store REGEX_TYPE \
        --default extended \
        --help "escape characters for an extended regular expression"
    parseargs-add-flag "-B/--basic" --const basic --store REGEX_TYPE \
        --help "escape characters for a basic regular expression"
    parseargs-add-flag "-P/--perl" --const perl --store REGEX_TYPE \
        --help "escape characters for a Perl regular expression"
    parseargs-add-flag "-A/--awk" --const awk --store REGEX_TYPE \
        --help "escape characters for an awk regular expression"
    parseargs-add-flag "-J/--javascript" --const javascript --store REGEX_TYPE \
        --help "escape characters for a JavaScript regular expression"
    parseargs-add-positional "STRING" --optional \
        --help "the string to escape (multiple args are joined with spaces)"
}


## helpful functions ###########################################################
################################################################################

# @description Escape a string for use in a basic regular expression
function escape-basic() {
    local string="${1}"

    # Escape the escaped regex characters
    sed -E '
        s/^\^/\\^/g
        s/\\[]{(|)}[]/\\&/g
        # TODO: Escape \+, \*, and \? unless they appear:
        # - at the beginning of the string
        # - after a "\(", "\|", or "\{"
        # - at the end of the string
        # s/^(.+)([^\\][^{(|])\\([+*?])$/\1\2\\&/g
        s/\\([+*?])/\\&/g
        s/\$$/\\$/g
    ' <<< "${string}"
}

# @description Escape a string for use in an extended regular expression
function escape-extended() {
    local string="${1}"

    # Escape the string
    sed -E '
        s/^\^/\\^/g
        s/[]{(.+*?|)}[]/\\&/g
        s/\$$/\\$/g
    ' <<< "${string}"
}

# @description Escape a string for use in a perl regular expression
function escape-perl() {
    local string="${1}"

    echo "\Q${string}\E"
}

# TODO: implement escape-awk and escape-javascript


## main ########################################################################
################################################################################

function main() {
    setup-options
    parseargs-parse-or-exit "${@}"

    local string="${PARSEARGS_POSARGS[*]}"

    # Ensure a string was provided
    if [[ -z "${string}" ]]; then
        echo "error: no string provided" >&2
        echo "${PARSEARGS_USAGE}" >&2
        return ${E_MISSING_ARGUMENT}
    fi

    # Try to find the escape function
    local escape_function="escape-${PARSEARGS_OPTS[REGEX_TYPE]}"
    if ! declare -F "${escape_function}" &>/dev/null; then
        echo "error: unknown regex type: ${PARSEARGS_OPTS[REGEX_TYPE]}" >&2
        return ${E_UNKNOWN_VALUE}
    fi

    # Escape the string
    "${escape_function}" "${string}"
}


## run #########################################################################
################################################################################

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "${@}"
