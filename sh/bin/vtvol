#!/usr/bin/env bash
# vtvol — VT-gated vol with lnotify feedback. The tmux-facing entry point:
# tracked .tmux.conf binds media keys here, and outside a text-VT context the
# whole thing is a silent no-op (GNOME et al. handle media keys themselves).
#
# The gate is SEAT-based, not caller-tty-based, on purpose: tmux run-shell
# executes from the tmux *server*, so this process always sees a pts and a
# naive `tty` check would never pass. Instead we ask "is the machine's
# console currently showing a text VT?" — which also matches the hardware
# nature of what we're adjusting. Rationale + design:
# sh/docs/plans/2026-07-06-unified-vol-bright-design.md §4.

vt_active() {
  : 'Gate: succeed only when the seat is on a non-graphical VT.

      No /sys/class/tty/tty0/active (macOS, containers, non-VT boxes) -> no.
      logind says the active session is graphical -> no.
      No logind to ask -> trust the kernel file and say yes.

      @return 0 when on a text VT, 1 otherwise
  '
  [[ -r /sys/class/tty/tty0/active ]] || return 1
  local sid type
  if command -v loginctl >/dev/null 2>&1; then
    sid=$(loginctl show-seat seat0 --property=ActiveSession --value 2>/dev/null)
    if [[ -n "$sid" ]]; then
      type=$(loginctl show-session "$sid" --property=Type --value 2>/dev/null)
      case "$type" in wayland|x11|mir) return 1 ;; esac
    fi
  fi
  return 0
}

notify() {
  : 'Toast via lnotify iff it is configured here; never fail the keybinding.
      @arg $1 group id  @arg $2 body
  '
  command -v lnotify >/dev/null 2>&1 || return 0
  lnotify --group "$1" --timeout 1500 --app vtcon "$2" >/dev/null 2>&1 || true
}

main() {
  vt_active || return 0

  # One vol invocation only — this runs on every keypress and each invocation
  # costs real milliseconds (bash + dispatcher). vol prints the resulting
  # state after a set, so the toast needs no follow-up queries.
  local self_dir out msg
  self_dir="$(dirname "$(readlink -f "$0")")"
  out="$("$self_dir/vol" "$@")" || return $?

  case "$1" in
    mute)  [[ "$out" == on ]] && msg="Muted" || msg="Unmuted" ;;
    muted) [[ "$out" == on ]] && msg="Muted" || msg="Not muted" ;;
    *)     msg="Volume: ${out}%" ;;
  esac
  notify volume "$msg"
}

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@"
