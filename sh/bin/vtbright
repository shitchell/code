#!/usr/bin/env bash
# vtbright — VT-gated bright with lnotify feedback. Companion to vtvol; see
# the gate rationale there and in
# sh/docs/plans/2026-07-06-unified-vol-bright-design.md §4.

vt_active() {
  : 'Gate: succeed only when the seat is on a non-graphical VT.
      @return 0 when on a text VT, 1 otherwise
  '
  [[ -r /sys/class/tty/tty0/active ]] || return 1
  local sid type
  if command -v loginctl >/dev/null 2>&1; then
    sid=$(loginctl show-seat seat0 --property=ActiveSession --value 2>/dev/null)
    if [[ -n "$sid" ]]; then
      type=$(loginctl show-session "$sid" --property=Type --value 2>/dev/null)
      case "$type" in wayland|x11|mir) return 1 ;; esac
    fi
  fi
  return 0
}

notify() {
  : 'Toast via lnotify iff it is configured here; never fail the keybinding.
      @arg $1 group id  @arg $2 body
  '
  command -v lnotify >/dev/null 2>&1 || return 0
  lnotify --group "$1" --timeout 1500 --app vtcon "$2" >/dev/null 2>&1 || true
}

main() {
  vt_active || return 0

  local self_dir
  self_dir="$(dirname "$(readlink -f "$0")")"
  "$self_dir/bright" "$@" >/dev/null || return $?

  notify brightness "Brightness: $("$self_dir/bright")%"
}

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@"
