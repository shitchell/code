#!/usr/bin/env bash
# clipout — print the clipboard. Strict text by default.
#
# NOTE on lib sourcing: the plan's template uses
#   source ".../lib/include.sh"; include-source 'clip.sh'
# but include-source searches $(pwd), <SHELL>_LIB_PATH, then PATH — none of
# which reliably point at this worktree's sh/lib (BASH_LIB_PATH on this machine
# resolves to the *main* repo, ~/code/sh/lib, which doesn't carry clip.sh). So
# we source the dispatcher directly by path relative to this script, which is
# deterministic regardless of cwd or environment.
source "$(dirname "$(readlink -f "$0")")/../lib/clip.sh"

main() {
  : 'Print the clipboard in the requested format.

      @arg --format <plain|rich|html|markdown|md|image>  output format (default plain)
      @arg --image   shorthand for --format image
      @stdout clipboard content in the requested format
      @return 0 on success; 2 unknown format; 3 missing provider/pandoc
  '
  local fmt=plain
  [[ "$1" == --format ]] && { fmt="$2"; shift 2; }
  [[ "$1" == --image ]] && { fmt=image; shift; }
  case "$fmt" in
    plain) clip::dispatch get plain ;;
    rich|html) clip::dispatch get rich ;;
    markdown|md)
      command -v pandoc >/dev/null \
        || { echo "clipout: pandoc required for --format markdown" >&2; exit 3; }
      # Capture rich (HTML) first so a missing rich provider surfaces its
      # exit code instead of being masked by pandoc succeeding on empty input.
      local html
      html="$(clip::dispatch get rich)" || exit $?
      printf '%s' "$html" | pandoc -f html -t gfm-raw_html --wrap=none ;;
    image) clip::dispatch get image ;;
    *) echo "clipout: unknown format: $fmt" >&2; exit 2 ;;
  esac
}
[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@"
