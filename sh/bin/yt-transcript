#!/usr/bin/env bash
#
# Download a youtube video transcript.
#
# Uses yt-dlp to fetch the video's caption track (preferring human-authored
# subtitles, falling back to auto-generated captions) in the timed "json3"
# format, then parses it with jq into per-line time + text segments.
#
# History: this previously spoke to the private youtubei `get_transcript`
# endpoint directly. That API kept changing its `params`/client-version
# handshake and eventually started returning HTTP 400 FAILED_PRECONDITION, so
# it was replaced with yt-dlp (which tracks YouTube's changes for us).

## imports #####################################################################
################################################################################

include-source 'echo.sh'
include-source 'debug.sh'
include-source 'text.sh'


## usage functions #############################################################
################################################################################

function help-usage() {
    echo "usage: $(basename "${0}") [-h] [-cv] [-f <format>] [-o <output file>] <video id | url>"
}

function help-epilogue() {
    echo "download a youtube video transcript"
}

function help-full() {
    help-usage
    help-epilogue
    echo
    echo "Uses yt-dlp to download a video transcript. The transcript is"
    echo "formatted as a list of lines, each line containing the time and text."
    echo "The format of each line can be specified using the --format option:"
    echo "    {timeStart}      the time the line starts in HH:MM:SS format"
    echo "    {timeEnd}        the time the line ends in HH:MM:SS format"
    echo "    {timeDuration}   the duration of the line in HH:MM:SS format"
    echo "    {text}           the text of the line"
    echo "    {n}              a newline character"
    echo "    {t}              a tab character"
    echo "    {{}              a literal { character"
    echo "    {}}              a literal } character"
    echo
    cat << EOF
    -h                         display usage
    --help                     display this help message
    -f / --format <format>     display each line of the transcript in the
                               specified format
                               (default: '{timeStart}  {text}')
    -c / --color               colorize the output
    --no-color                 do not colorize the output
    --color-time <ansi code>   colorize the time using the specified ansi code.
                               if specified, implies --color (default: 1)
    --color-text <ansi code>   colorize the text using the specified ansi code
                               if specified, implies --color (default: 0)
    -l/--lang <language code>  the language code of the transcript to download
                               if available (default: en)
    --no-cache                 do not read from or write to the transcript cache
    --refresh                  ignore any cached copy and re-fetch, updating the
                               cache
    -v                         verbose output
    -o <output file>           write the transcript to the specified file

Fetched transcripts are cached under ~/.cache/yt-transcript as
<video id>.<lang>.json3 to avoid repeat network requests (YouTube rate-limits
yt-dlp quickly without a signed-in session).
EOF
}

function parse-args() {
    # Default values
    VERBOSE=0
    DO_COLOR=0
    COLOR_TIME=1
    COLOR_TEXT=0
    FORMAT="{timeStart}  {text}"
    OUTPUT_FILE=""
    SUB_LANG=""
    USE_CACHE=1
    REFRESH_CACHE=0

    # Loop over the arguments
    while [[ ${#} -gt 0 ]]; do
        case ${1} in
            -h)
                help-usage
                help-epilogue
                exit 0
                ;;
            --help)
                help-full
                exit 0
                ;;
            -c | --color)
                DO_COLOR=1
                shift 1
                ;;
            --no-color)
                DO_COLOR=0
                shift 1
                ;;
            --color-time)
                COLOR_TIME="${2}"
                DO_COLOR=1
                shift 2
                ;;
            --color-text)
                COLOR_TEXT="${2}"
                DO_COLOR=1
                shift 2
                ;;
            -l | --lang)
                SUB_LANG="${2}"
                shift 2
                ;;
            -f | --format)
                FORMAT="${2}"
                shift 2
                ;;
            --no-cache)
                USE_CACHE=0
                shift 1
                ;;
            --refresh)
                REFRESH_CACHE=1
                shift 1
                ;;
            -v)
                VERBOSE=1
                shift 1
                ;;
            -o)
                OUTPUT_FILE="${2}"
                shift 2
                ;;
            *)
                if [[ -z "${VIDEO_ID}" ]]; then
                    VIDEO_ID="$(parse-video-id "${1}")"
                    if [[ ${?} -eq 1 ]]; then
                        echo-error "invalid video id: ${1}"
                        help-usage
                        exit 1
                    fi
                    shift 1
                else
                    echo-error "too many arguments"
                    help-usage
                    exit 1
                fi
                ;;
        esac
    done

    # Check for required arguments
    if [[ -z "${VIDEO_ID}" ]]; then
        echo-error "missing required argument: video id"
        help-usage
        exit 1
    fi
}


## helpful functions ###########################################################
################################################################################

# @description Verify that required external tools are installed
# @usage check-dependencies
function check-dependencies() {
    local dep missing=()

    for dep in yt-dlp jq; do
        command -v "${dep}" &>/dev/null || missing+=("${dep}")
    done

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo-error "missing required dependencies: ${missing[*]}"
        echo-error "install with e.g.: pipx install yt-dlp && apt install jq"
        return 1
    fi
}

function parse-video-id() {
    local string="${1}"
    local video_id

    debug "parsing video id from string: ${string}"

    # If the video id is a url, extract the video id
    if [[ "${string}" =~ youtube.com ]]; then
        video_id="$(echo "${string}" | sed -E 's/.*[?&]v=([^&]+).*/\1/')"
        debug "parsed from youtube.com: ${video_id}"
    elif [[ "${string}" =~ youtu.be ]]; then
        video_id="$(echo "${string}" | sed -E 's/.*youtu.be\/([^?]+).*/\1/')"
        debug "parsed from youtu.be: ${video_id}"
    elif [[ "${string}" =~ ^[a-zA-Z0-9_-]{11}$ ]]; then
        video_id="${string}"
        debug "parsed from video id: ${video_id}"
    else
        debug "failed to parse video id"
        return 1
    fi

    echo "${video_id}"
}

# @description Convert milliseconds to HH:MM:SS, storing the result in a variable
# @usage ms-to-hms-var <varname> <milliseconds>
# @arg $1 {string} name of the variable to assign the result to
# @arg $2 {number} milliseconds
function ms-to-hms-var() {
    local __ms="${2}" __s __m __h

    __s=$(( __ms / 1000 ))
    __m=$(( __s / 60 ))
    __h=$(( __m / 60 ))

    # printf -v assigns without a subshell, keeping this cheap for long
    # transcripts (thousands of segments)
    printf -v "${1}" '%02d:%02d:%02d' "$(( __h ))" "$(( __m % 60 ))" "$(( __s % 60 ))"
}

# @description Fetch a video's caption track as json3 via yt-dlp
# @usage yt-transcript-fetch-json3 <video id> [<lang>]
# @arg $1 {string} video id
# @arg $2 {string} language code (default: en)
# @stdout the json3 caption document
function yt-transcript-fetch-json3() {
    local video_id="${1}"
    local lang="${2:-en}"
    local url="https://www.youtube.com/watch?v=${video_id}"
    local cache_dir="${HOME}/.cache/yt-transcript"
    local cache_file="${cache_dir}/${video_id}.${lang}.json3"
    local tmpdir base file mode
    local yt_err=/dev/null

    # Surface yt-dlp's own chatter only in verbose mode
    [[ "${VERBOSE}" -eq 1 ]] && yt_err=/dev/stderr

    # Serve from cache when possible. Transcripts are effectively immutable, and
    # YouTube rate-limits/blocks yt-dlp quickly without a signed-in session, so
    # caching by <video>.<lang> avoids repeat network hits. --refresh forces a
    # re-fetch; --no-cache disables both reading and writing.
    if [[ "${USE_CACHE}" -eq 1 && "${REFRESH_CACHE}" -ne 1 && -s "${cache_file}" ]]; then
        debug "serving transcript from cache: ${cache_file}"
        cat "${cache_file}"
        return 0
    fi

    # NOTE: this function's stdout is the JSON data channel (piped into jq), so
    # every diagnostic here must be forced to stderr -- echo-error writes to
    # stdout by default, which would otherwise corrupt the pipe.
    tmpdir="$(mktemp -d)" || {
        echo-error "could not create temporary directory" >&2
        return 1
    }
    base="${tmpdir}/sub"

    # Prefer human-authored subtitles; fall back to auto-generated captions
    for mode in --write-subs --write-auto-subs; do
        debug "fetching subtitles via yt-dlp ${mode} (lang=${lang})"
        yt-dlp --quiet --no-warnings --skip-download "${mode}" \
            --sub-langs "${lang}" --sub-format json3 \
            -o "${base}" "${url}" 2>"${yt_err}"
        file="$(ls "${base}".*.json3 2>/dev/null | head -n1)"
        [[ -s "${file}" ]] && break
        file=""
    done

    if [[ -z "${file}" ]]; then
        rm -rf "${tmpdir}"
        echo-error "no '${lang}' transcript available for video: ${video_id}" >&2
        return 1
    fi

    # Populate the cache (best-effort -- a cache miss must never fail the fetch)
    if [[ "${USE_CACHE}" -eq 1 ]] && mkdir -p "${cache_dir}" 2>/dev/null; then
        if cp "${file}" "${cache_file}" 2>/dev/null; then
            debug "cached transcript to: ${cache_file}"
        fi
    fi

    debug "using subtitle file: ${file}"
    cat "${file}"
    rm -rf "${tmpdir}"
}

# @description Convert a json3 caption document into start/dur/text TSV
# @usage yt-transcript-json3-to-tsv < json3
# @stdin the json3 caption document
# @stdout tab-separated: <startMs> <durationMs> <text>
function yt-transcript-json3-to-tsv() {
    # json3 events carry timing (tStartMs/dDurationMs) plus one or more text
    # `segs`. Rolling auto-captions emit whitespace-only filler events between
    # real lines; collapsing whitespace and dropping empties removes those.
    jq -r '
        .events[]?
        | select(.segs != null)
        | { s: (.tStartMs // 0),
            d: (.dDurationMs // 0),
            t: ([.segs[].utf8] | join("") | gsub("\\s+"; " ") | gsub("^ +| +$"; "")) }
        | select(.t != "")
        | [.s, .d, .t]
        | @tsv
    '
}

# @description Split a format template into alternating literal/token parts
# @usage parse-format <format>
# @arg $1 {string} the format template
# @sets FMT_LITERALS array of literal chunks (one more element than FMT_TOKENS)
# @sets FMT_TOKENS array of token names, interleaved between the literals
function parse-format() {
    local fmt="${1}"
    local n=${#fmt} i=0 tok tlen lit=""

    FMT_LITERALS=()
    FMT_TOKENS=()

    while (( i < n )); do
        # Try to match a known token at the current position. Braces are
        # literal in `case` glob patterns, so these match exactly.
        tok=""
        case "${fmt:i}" in
            '{timeStart}'*)    tok="timeStart";    tlen=11 ;;
            '{timeEnd}'*)      tok="timeEnd";      tlen=9  ;;
            '{timeDuration}'*) tok="timeDuration"; tlen=13 ;;
            '{text}'*)         tok="text";         tlen=6  ;;
            '{n}'*)            tok="n";            tlen=3  ;;
            '{t}'*)            tok="t";            tlen=3  ;;
            '{{}'*)            tok="lbrace";       tlen=3  ;;
            '{}}'*)            tok="rbrace";       tlen=3  ;;
        esac
        if [[ -n "${tok}" ]]; then
            FMT_LITERALS+=( "${lit}" )
            FMT_TOKENS+=( "${tok}" )
            lit=""
            (( i += tlen ))
        else
            lit+="${fmt:i:1}"
            (( i++ ))
        fi
    done
    FMT_LITERALS+=( "${lit}" )
}

# @description Format start/dur/text TSV lines using the requested FORMAT
# @usage format-transcript < tsv
# @stdin tab-separated: <startMs> <durationMs> <text>
# @stdout the formatted transcript
function format-transcript() {
    local ts="" te="" xs="" xe=""

    # Build the ANSI wrappers once (empty when color is disabled)
    if [[ "${DO_COLOR}" -eq 1 ]]; then
        ts=$'\e['"${COLOR_TIME}"'m'; te=$'\e[0m'
        xs=$'\e['"${COLOR_TEXT}"'m'; xe=$'\e[0m'
    fi

    # Pre-parse the template once, then assemble each line by pure
    # concatenation. No replacement engine ever sees the transcript text, so
    # `&`, `\`, and even a stray `{text}` in the captions are inserted
    # verbatim -- and a literal brace token like `{{}` can't be re-interpreted.
    parse-format "${FORMAT}"

    local sms dms text start_hms end_hms dur_hms out i
    while IFS=$'\t' read -r sms dms text; do
        ms-to-hms-var start_hms "${sms}"
        ms-to-hms-var end_hms   "$(( sms + dms ))"
        ms-to-hms-var dur_hms   "${dms}"

        out="${FMT_LITERALS[0]}"
        for (( i = 0; i < ${#FMT_TOKENS[@]}; i++ )); do
            case "${FMT_TOKENS[i]}" in
                timeStart)    out+="${ts}${start_hms}${te}" ;;
                timeEnd)      out+="${ts}${end_hms}${te}" ;;
                timeDuration) out+="${ts}${dur_hms}${te}" ;;
                text)         out+="${xs}${text}${xe}" ;;
                n)            out+=$'\n' ;;
                t)            out+=$'\t' ;;
                lbrace)       out+='{' ;;
                rbrace)       out+='}' ;;
            esac
            out+="${FMT_LITERALS[i+1]}"
        done
        printf '%s\n' "${out}"
    done
}

# @description Download a youtube video transcript
# @usage get-transcript <video id> [<output file>] [<lang>]
# @arg $1 {string} video id
# @arg $2 {string} output file
# @arg $3 {string} language code
# @return {string} transcript
function get-transcript() {
    local video_id="${1}"
    local output_file="${2}"
    local lang="${3}"
    local tsv

    # Fetch + parse first so a fetch failure isn't masked by the format stage
    tsv="$(yt-transcript-fetch-json3 "${video_id}" "${lang}" | yt-transcript-json3-to-tsv)"
    if [[ -z "${tsv}" ]]; then
        # yt-transcript-fetch-json3 already reported the reason
        return 1
    fi

    if [[ -z "${output_file}" ]]; then
        debug "printing transcript to stdout"
        printf '%s\n' "${tsv}" | format-transcript
    else
        debug "writing transcript to '${output_file}'"
        printf '%s\n' "${tsv}" | format-transcript > "${output_file}"
    fi
}


## main ########################################################################
################################################################################

function main() {
    check-dependencies || exit 1
    parse-args "${@}"

    get-transcript "${VIDEO_ID}" "${OUTPUT_FILE}" "${SUB_LANG}"
}


## run #########################################################################
################################################################################

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "${@}"
