#!/usr/bin/env bash
#
# Find files by mimetype and charset


## imports #####################################################################
################################################################################

include-source 'parseargs.sh'


## options #####################################################################
################################################################################

function setup-options() {
    parseargs-set-usage "usage: $(basename "${0}") [-h] [-m/--mimetype <mimetype>] [-c/--charset <charset>] [-x/--exclude <pattern>] [-i/--include <pattern>] [-g/--glob] [-E/--regex] [directory ...]"
    parseargs-set-help "find files by mimetype and charset"
    parseargs-add-parameter "-m/--mimetype" --repeat --store MIMETYPES \
        --help "only show files with this mimetype (repeatable)"
    parseargs-add-parameter "-c/--charset" --repeat --store CHARSETS \
        --help "only show files with this charset (repeatable)"
    parseargs-add-parameter "-x/--exclude" --repeat --store EXCLUDE_PATTERNS \
        --help "exclude filepaths matching this pattern (repeatable)"
    parseargs-add-parameter "-i/--include" --repeat --store INCLUDE_PATTERNS \
        --help "only include filepaths matching this pattern (repeatable)"
    parseargs-add-flag "-g/--glob" --const glob --store PATTERN_TYPE \
        --default glob --help "match patterns as globs"
    parseargs-add-flag "-E/--regex" --const regex --store PATTERN_TYPE \
        --help "match patterns as regular expressions"
    parseargs-add-parameter "-F/--separator" --store SEPARATOR \
        --help "separator between filepath and mimetype for -M (default: tab)"
    parseargs-add-flag "-M/--show-mimetype" --store DO_SHOW_MIMETYPE \
        --help "show each file's mimetype after the separator"
    parseargs-add-positional "directory" --optional \
        --help "directories to search (default: .)"
}


## helpful functions ###########################################################
################################################################################

# @description Check an item against patterns; true if none given
# @usage match <item> [<pattern> ...]
function match-glob() {
    local item="${1}" patterns=("${@:2}") is_match=true
    if [[ ${#patterns[@]} -gt 0 ]]; then
        is_match=false
        for pattern in "${patterns[@]}"; do
            [[ "${item}" == ${pattern} ]] && is_match=true && break
        done
    fi
    ${is_match}
}

function match-regex() {
    local item="${1}" patterns=("${@:2}") is_match=true
    if [[ ${#patterns[@]} -gt 0 ]]; then
        is_match=false
        for pattern in "${patterns[@]}"; do
            [[ "${item}" =~ ${pattern} ]] && is_match=true && break
        done
    fi
    ${is_match}
}


## main ########################################################################
################################################################################

function main() {
    setup-options
    parseargs-parse-or-exit "${@}"

    local directories=("${PARSEARGS_POSARGS[@]}")
    [[ ${#directories[@]} -eq 0 ]] && directories=(".")

    local separator="${PARSEARGS_OPTS[SEPARATOR]-$'\t'}"
    local do_show_mimetype="${PARSEARGS_OPTS[DO_SHOW_MIMETYPE]:-false}"
    local match="match-${PARSEARGS_OPTS[PATTERN_TYPE]}"

    local line filepath mimetype filetype charset is_match

    # Use `find` to get the files
    find "${directories[@]}" -exec file -F $'\1' --mime {} + \
    | while read -r line; do
        filepath="${line%$'\1'*}"
        mimetype=$(sed -E $'s/[^\1]+\1 *//' <<< "${line}")
        filetype="${mimetype%%;*}"
        charset="${mimetype##*; }"
        charset="${charset#charset=}"

        if [[ ${#MIMETYPES[@]} -gt 0 ]]; then
            "${match}" "${filetype}" "${MIMETYPES[@]}" || continue
        fi

        if [[ ${#CHARSETS[@]} -gt 0 ]]; then
            "${match}" "${charset}" "${CHARSETS[@]}" || continue
        fi

        # Check the filepath matches
        is_match=true
        [[ ${#INCLUDE_PATTERNS[@]} -gt 0 ]] && {
            is_match=false
            "${match}" "${filepath}" "${INCLUDE_PATTERNS[@]}" && is_match=true
        }
        [[ ${#EXCLUDE_PATTERNS[@]} -gt 0 ]] && {
            "${match}" "${filepath}" "${EXCLUDE_PATTERNS[@]}" && is_match=false
        }
        if ${is_match}; then
            if ${do_show_mimetype}; then
                printf '%s%s%s\n' "${filepath}" "${separator}" "${filetype}"
            else
                echo "${filepath}"
            fi
        fi
    done
}


## run #########################################################################
################################################################################

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "${@}"
