#!/usr/bin/env bash
#
# claude-find-sessions -- locate recently-active Claude Code sessions and show
# their names + a hint of what was happening, so you can recover the right one
# after a tmux/laptop crash.
#
# Sessions live at  ~/.claude/projects/<slug-of-cwd>/<uuid>.jsonl
# and the file mtime tracks last activity. For each session we surface:
#   - aiTitle      : Claude's auto-generated 3-4 word topic slug
#   - rename       : the /rename marker (<local-command-stdout>Session renamed to: X)
#   - custom-title : a manually-set title
#   - cwd          : the working directory it ran in
#   - last         : a snippet of the final message (what you were mid-doing)
#   - live         : ◉ if a claude process is live in this session right now;
#                    ⚠ UNCLEAN EXIT if a marker survived with no live process
#                    (started but never closed cleanly -- a crash). A session
#                    resumed in N terminals shows N markers (◉ live ×N).
#
# Usage:
#   claude-find-sessions [options]
#
#   -b, --bucket UNIT   group output by mtime: hour | day | week | month
#   -n, --named-only    only sessions that were manually named (/rename or custom-title)
#   -N, --named-first   sort named sessions to the top (within each bucket)
#   -p, --project PAT   only sessions whose cwd or project-dir matches PAT (substring)
#   -d, --days N        only sessions modified within the last N days
#   -l, --limit N       show at most N sessions (default 25)
#   -a, --all           no limit
#   -h, --help          this help
#
set -u

PROJECTS_DIR="${CLAUDE_PROJECTS_DIR:-$HOME/.claude/projects}"
LIVE_DIR="${CLAUDE_SESSION_LIVE_DIR:-$HOME/.claude/live}"

BUCKET=""        # "" | hour | day | week | month
NAMED_ONLY=0
NAMED_FIRST=0
PROJECT_PAT=""
DAYS=""
LIMIT=25

die() { echo "claude-find-sessions: $*" >&2; exit 2; }

usage() { sed -n '2,/^set -u/{/^set -u/!p}' "$0" | sed 's/^# \{0,1\}//'; exit 0; }

while [[ $# -gt 0 ]]; do
    case "$1" in
        -b|--bucket)      BUCKET="${2:-}"; shift 2 ;;
        -n|--named-only)  NAMED_ONLY=1; shift ;;
        -N|--named-first) NAMED_FIRST=1; shift ;;
        -p|--project)     PROJECT_PAT="${2:-}"; shift 2 ;;
        -d|--days)        DAYS="${2:-}"; shift 2 ;;
        -l|--limit)       LIMIT="${2:-}"; shift 2 ;;
        -a|--all)         LIMIT=0; shift ;;
        -h|--help)        usage ;;
        *) die "unknown option: $1 (try --help)" ;;
    esac
done

case "$BUCKET" in ""|hour|day|week|month) ;; *) die "--bucket must be hour|day|week|month" ;; esac
[[ -n "$DAYS"  && ! "$DAYS"  =~ ^[0-9]+$ ]] && die "--days must be an integer"
[[ -n "$LIMIT" && ! "$LIMIT" =~ ^[0-9]+$ ]] && die "--limit must be an integer"
[[ -d "$PROJECTS_DIR" ]] || die "no projects dir at $PROJECTS_DIR"

NOW="$(date +%s)"
CUTOFF=0
[[ -n "$DAYS" ]] && CUTOFF=$(( NOW - DAYS * 86400 ))

# --- field extractors (grep-based; cheap, format-agnostic) -------------------

ai_title()     { grep -aoP '"aiTitle":"\K[^"]*'                              "$1" 2>/dev/null | tail -1; }
custom_title() { grep -aoP '"customTitle":"\K[^"]*'                          "$1" 2>/dev/null | tail -1; }
rename_mark()  { grep -aoP '"content":"<local-command-stdout>Session renamed to: \K[^<]+' "$1" 2>/dev/null | tail -1; }
session_cwd()  { grep -aoP '"cwd":"\K[^"]*'                                   "$1" 2>/dev/null | head -1; }

# Fallback when there's no aiTitle: the first genuinely-typed user prompt.
# Skips meta-wrapped (<...>) and serialized-stub ({...}) content. Only the
# head of the file is scanned -- the opening prompt is always near the top.
first_prompt() {
    head -n 200 "$1" 2>/dev/null | jq -rc '
        select(.type=="user")
        | select((.isMeta // false) | not)
        | select((.message.content|type)=="string")
        | .message.content | gsub("[\n\t\r]+";" ")' 2>/dev/null \
        | grep -avE '^[<{]' \
        | head -1 \
        | tr '\n\t' '  ' | sed -E 's/  +/ /g; s/^ //; s/ $//' \
        | cut -c1-70
}

# bytes -> human units via integer math only (no bc/df, no subprocess).
human_size() {
    local b=$1
    if   (( b >= 1073741824 )); then printf '%d.%dG' $(( b/1073741824 )) $(( b%1073741824*10/1073741824 ))
    elif (( b >= 1048576 ));    then printf '%d.%dM' $(( b/1048576 ))    $(( b%1048576*10/1048576 ))
    elif (( b >= 1024 ));       then printf '%dK'    $(( b/1024 ))
    else                             printf '%dB'    "$b"
    fi
}

# A session is "named" if it was manually titled (/rename or custom-title).
# aiTitle is automatic and present on nearly every session, so it doesn't count.
is_named() {
    grep -aqE '("customTitle":)|("content":"<local-command-stdout>Session renamed to: )' "$1" 2>/dev/null
}

# Throwaway summariser sub-sessions: the SessionEnd hook spawns `claude -p` whose
# first user message is the wrapper '<transcript>...Rules:...'. That signature
# ('"content":"<transcript>') only ever appears at the START of such a session,
# so a cheap head-of-file grep identifies (and lets us hide) them.
is_summarizer() {
    head -n 10 "$1" 2>/dev/null | grep -q '"content":"<transcript>'
}

# Snippet of the final real message (skips meta/command/transcript wrappers).
last_message() {
    tail -n 500 "$1" 2>/dev/null | jq -rc '
        select(.type=="user" or .type=="assistant")
        | select((.isMeta // false) | not)
        | select((.isSidechain // false) | not)
        | (.message.content) as $c
        | (if   ($c|type)=="string" then $c
           elif ($c|type)=="array"  then ([$c[]? | select(.type=="text") | .text] | join(" "))
           else "" end)
        | gsub("[\n\t\r]+";" ")
        | select(type=="string" and (.|length) > 0)
    ' 2>/dev/null \
        | grep -avE '^<(transcript|local-command|command-|system-)' \
        | tail -1 \
        | tr '\n\t' '  ' | sed -E 's/  +/ /g; s/^ //; s/ $//' \
        | cut -c1-140
}

# --- bucket helpers ----------------------------------------------------------

bucket_key() {  # sortable, lexical-desc == chrono-desc
    case "$BUCKET" in
        hour)  date -d "@$1" +%Y-%m-%dT%H ;;
        day)   date -d "@$1" +%Y-%m-%d ;;
        week)  date -d "@$1" +%G-W%V ;;
        month) date -d "@$1" +%Y-%m ;;
        *)     echo _ ;;
    esac
}
bucket_header() {
    case "$BUCKET" in
        hour)  date -d "@$1" '+%A %Y-%m-%d %H:00' ;;
        day)   date -d "@$1" '+%A, %B %-d %Y' ;;
        week)  date -d "@$1" '+Week %V, %G' ;;
        month) date -d "@$1" '+%B %Y' ;;
    esac
}

rel_age() {
    local d=$(( NOW - $1 ))
    if   (( d < 60 ));    then echo "just now"
    elif (( d < 3600 ));  then echo "$(( d/60 ))m ago"
    elif (( d < 86400 )); then echo "$(( d/3600 ))h ago"
    elif (( d < 604800 ));then echo "$(( d/86400 ))d ago"
    else date -d "@$1" '+%Y-%m-%d'
    fi
}

# --- gather ------------------------------------------------------------------

shopt -s nullglob
records=()   # "bucketkey \t epoch \t named \t file"
for f in "$PROJECTS_DIR"/*/*.jsonl; do
    stat_out=$(stat -c '%Y %s' "$f" 2>/dev/null) || continue
    epoch=${stat_out% *}; bytes=${stat_out#* }
    (( CUTOFF && epoch < CUTOFF )) && continue

    is_summarizer "$f" && continue

    if [[ -n "$PROJECT_PAT" ]]; then
        dir="$(basename "$(dirname "$f")")"
        cwd="$(session_cwd "$f")"
        [[ "$dir" == *"$PROJECT_PAT"* || "$cwd" == *"$PROJECT_PAT"* ]] || continue
    fi

    named=0
    if is_named "$f"; then named=1; fi
    (( NAMED_ONLY && named == 0 )) && continue

    printf -v rec '%s\t%s\t%s\t%s\t%s' "$(bucket_key "$epoch")" "$epoch" "$named" "$bytes" "$f"
    records+=("$rec")
done

if [[ ${#records[@]} -eq 0 ]]; then
    echo "No matching sessions."
    exit 0
fi

# --- sort --------------------------------------------------------------------
# bucketkey desc, then (optionally) named desc, then mtime desc.
if (( NAMED_FIRST )); then
    sort_args=(-t$'\t' -k1,1r -k3,3nr -k2,2nr)
else
    sort_args=(-t$'\t' -k1,1r -k2,2nr)
fi
mapfile -t records < <(printf '%s\n' "${records[@]}" | sort "${sort_args[@]}")

# --- limit -------------------------------------------------------------------
total=${#records[@]}
if (( LIMIT > 0 && total > LIMIT )); then
    records=("${records[@]:0:LIMIT}")
fi

# --- render ------------------------------------------------------------------
prev_bucket="__none__"
shown=0
for rec in "${records[@]}"; do
    IFS=$'\t' read -r bkey epoch named bytes f <<<"$rec"
    shown=$((shown+1))

    if [[ -n "$BUCKET" && "$bkey" != "$prev_bucket" ]]; then
        prev_bucket="$bkey"
        printf '\n\033[1;34m== %s ==\033[0m\n' "$(bucket_header "$epoch")"
    fi

    uuid="$(basename "$f" .jsonl)"
    short="${uuid:0:8}"
    title="$(ai_title "$f")"; tsrc=""
    if [[ -z "$title" ]]; then
        title="$(first_prompt "$f")"
        [[ -n "$title" ]] && tsrc=" \033[2m·prompt\033[0m"
    fi
    [[ -z "$title" ]] && { title='(untitled)'; tsrc=''; }
    cwd="$(session_cwd "$f")"
    rn="$(rename_mark "$f")"
    ct="$(custom_title "$f")"
    last="$(last_message "$f")"

    # Live markers: one per (session, process). Aggregate across all of them,
    # since the same session can be resumed in multiple terminals at once.
    livemark=""
    live_pids=(); stale_n=0
    for m in "$LIVE_DIR/$uuid".live "$LIVE_DIR/$uuid".*.live; do
        [[ -e "$m" ]] || continue
        base="$(basename "$m" .live)"               # <uuid> or <uuid>.<pid>
        if [[ "$base" == *.* ]]; then p="${base##*.}"; else p="$(grep -m1 '^claude_pid=' "$m" | cut -d= -f2-)"; fi
        if [[ -n "$p" && "$(cat "/proc/$p/comm" 2>/dev/null)" =~ ^(claude|node)$ ]]; then
            live_pids+=("$p")
        else
            stale_n=$((stale_n+1))
        fi
    done
    if (( ${#live_pids[@]} > 0 )); then
        if (( ${#live_pids[@]} == 1 )); then
            livemark=" \033[32m◉ live (pid ${live_pids[0]})\033[0m"
        else
            livemark=" \033[32m◉ live ×${#live_pids[@]} (pids $(IFS=,; echo "${live_pids[*]}"))\033[0m"
        fi
        (( stale_n > 0 )) && livemark+=" \033[31m+${stale_n} stale\033[0m"
    elif (( stale_n > 0 )); then
        if (( stale_n == 1 )); then
            livemark=" \033[31m⚠ UNCLEAN EXIT\033[0m"
        else
            livemark=" \033[31m⚠ UNCLEAN EXIT ×${stale_n}\033[0m"
        fi
    fi

    printf '\033[1m● %s\033[0m%b  \033[2m%s · %s  %s\033[0m%b\n' \
        "$title" "$tsrc" "$(rel_age "$epoch")" "$(human_size "$bytes")" "$short" "$livemark"
    [[ -n "$rn" ]] && printf '    \033[36mrename:\033[0m %s\n' "$rn"
    [[ -n "$ct" && "$ct" != "$rn" ]] && printf '    \033[36mcustom:\033[0m %s\n' "$ct"
    [[ -n "$cwd"  ]] && printf '    \033[2mcwd:\033[0m    %s\n' "${cwd/#$HOME/\~}"
    [[ -n "$last" ]] && printf '    \033[2mlast:\033[0m   %s\n' "$last"
done

printf '\n\033[2m%d shown' "$shown"
(( total > shown )) && printf ' of %d (use --all or --limit)' "$total"
printf '\033[0m\n'
